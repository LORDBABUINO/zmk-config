    // Umlaut
    a_umlaut {
      bindings = <&kp RA(Q)>;
      key-positions = <13 25>;
      layers = <0>;
      timeout-ms = <30>;
    };
    o_umlaut {
      bindings = <&kp RA(P)>;
      key-positions = <9 34>;
      layers = <0>;
      timeout-ms = <30>;
    };
    u_umlaut {
      bindings = <&kp RA(Y)>;
      key-positions = <7 21>;
      layers = <0>;
      timeout-ms = <30>;
    };
    // Cedilla
    c_cedilla {
      bindings = <&kp RA(C)>;
      key-positions = <27 32>;
      layers = <0>;
      timeout-ms = <30>;
    };

    // Number Layer

    // Symbols
         excl {
      bindings = <&kp      EXCL>;
      key-positions = <1 13>;
      layers = <1>;
      timeout-ms = <30>;
        };
           at {
      bindings = <&kp        AT>;
      key-positions = <2 14>;
      layers = <1>;
      timeout-ms = <30>;
          };
         hash {
      bindings = <&kp      HASH>;
      key-positions = <3 15>;
      layers = <1>;
      timeout-ms = <30>;
        };
       dollar {
      bindings = <&kp    DOLLAR>;
      key-positions = <4 16>;
      layers = <1>;
      timeout-ms = <30>;
      };
      percent {
      bindings = <&kp   PERCENT>;
      key-positions = <5 17>;
      layers = <1>;
      timeout-ms = <30>;
      };
        caret {
      bindings = <&kp     CARET>;
      key-positions = <13 25>;
      layers = <1>;
      timeout-ms = <30>;
        };
    ampersand {
      bindings = <&kp AMPERSAND>;
      key-positions = <14 26>;
      layers = <1>;
      timeout-ms = <30>;
    };
         star {
      bindings = <&kp      STAR>;
      key-positions = <15 27>;
      layers = <1>;
      timeout-ms = <30>;
        };
         lpar {
      bindings = <&kp      LPAR>;
