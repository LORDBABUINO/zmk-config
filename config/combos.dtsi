        };
         rpar {
      bindings = <&kp      RPAR>;
      key-positions = <17 29>;
      layers = <1>;
      timeout-ms = <30>;
        };
    // Bluetooth
    bt_clear {
      bindings = <&bt BT_CLR>;
      key-positions = <1 2 3 4>;
      layers = <1>;
      timeout-ms = <30>;
    };
    bt_sel_0 {
      bindings = <&bt BT_SEL 0>;
      key-positions = <6  18>;
      layers = <1>;
      timeout-ms = <30>;
    };
    bt_sel_1 {
      bindings = <&bt BT_SEL 1>;
      key-positions = <7  19>;
      layers = <1>;
      timeout-ms = <30>;
    };
    bt_sel_2 {
      bindings = <&bt BT_SEL 2>;
      key-positions = <8  20>;
      layers = <1>;
      timeout-ms = <30>;
    };
    bt_sel_3 {
      bindings = <&bt BT_SEL 3>;
      key-positions = <9  21>;
      layers = <1>;
      timeout-ms = <30>;
    };
    bt_sel_4 {
      bindings = <&bt BT_SEL 4>;
      key-positions = <10 22>;
      layers = <1>;
      timeout-ms = <30>;
    };
    // Copy & Paste
     undo {
      bindings = <&kp  K_UNDO>;
      key-positions = <18 19>;
      layers = <1>;
      timeout-ms = <30>;
    };
     copy {
      bindings = <&kp  K_COPY>;
      key-positions = <19 20>;
      layers = <1>;
      timeout-ms = <30>;
    };
    paste {
      bindings = <&kp K_PASTE>;
      key-positions = <20 21>;
      layers = <1>;
      timeout-ms = <30>;
    };
      cut {
      bindings = <&kp   K_CUT>;
      key-positions = <21 22>;
      layers = <1>;
      timeout-ms = <30>;
      };
     redo {
      bindings = <&kp  K_REDO>;
      key-positions = <22 23>;
      layers = <1>;
      timeout-ms = <30>;
    };
